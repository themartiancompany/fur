_fur_tree_dir_clean() {
  local \
    _repo_dir="${1}" \
    _msg=()
  if [[ -e "${_repo_dir}/fur" ]]; then
    _msg=(
      "Fur directory exists"
      "already in '${_repo_dir}',"
      "deleting."
    )
    _msg_info \
      "${_msg[*]}"
    rm \
      -rf \
      "${_repo_dir}/fur" || \
    true
  fi
}

_fur_tree_get() {
  local \
    _pkg="${1}" \
    _mirror="${2}" \
    _repo_dir="${3}" \
    _git_opts=() \
    _clone_opts=() \
    _url \
    _pkgs=() \
    _pkgs_set=() \
    _oldpwd \
    _dir \
    _pkgname \
    _pkg_file \
    _pkg_filename \
    _msg=()
  if [[ "${_target_platform}" == "android" ]]; then
    _target_platform="termux"
  fi
  if [[ "${quiet}" == "y" ]]; then
    _clone_opts+=(
      --quiet
    )
  fi
  _msg=(
    "Downloading '${_pkg}'."
    "Remaining packages '${_packages_to_retrieve[@]}'"
  )
  _msg_info \
    "${_msg[*]}"
  _clone_opts+=(
    --single-branch
    --depth=1
  )
  _git_opts+=(
    "${_clone_opts[@]}"
    --branch="${_pkg}"
  )
  _mirror_get \
    "${_mirror}" \
    "${_target_namespace}" \
    "${_git_protocol}"
  _oldpwd="${PWD}"
  cd \
    "${_repo_dir}"
  _fur_tree_dir_clean \
    "${_repo_dir}"
  git \
    clone \
      "${_git_opts[@]}" \
      "${_url}" \
      "fur"
  _depends_retrieved+=(
    "${_pkg}"
  )
  _msg=(
    "Removing extra platforms."
  )
  _msg_info \
    "${_msg[*]}"
  for _dir in "fur/"*; do
    _platform="$(
      basename \
        "${_dir}")"
    if [[ ! -d "${_dir}" || \
          "${_platform}" != "${_target_platform}" ]]; then
      rm \
        -rf \
        "${_dir}" || \
      true
    fi
  done
  _sigs_get \
    "${_repo_dir}/fur"
  if [[ "${_sigs[*]}" == "" ]]; then
    _msg=(
      "Found no signatures"
      "into '${_repo_dir}'."
    )
    _msg_error \
      "${_msg[*]}" \
      1
  fi
  _msg=(
    "Found and moving signatures '${_sigs[*]}'"
    "into '${_repo_dir}'."
  )
  _msg_info \
    "${_msg[*]}"
  for _sig in "${_sigs[@]}"; do
    mv \
      "${_sig}" \
      "${_repo_dir}" || ( \
      _msg=(
        "Error moving '${_sig}' into"
        "'${_repo_dir}'."
      ) && \
      _msg_error \
        "${_msg[*]}" \
        0 )
  done
  _pkgs_repo_get \
    "${_repo_dir}/fur"
  if [[ "${_pkgs[*]}" == "" ]]; then
    _msg=(
      "Found no packages."
    )
    _msg_error \
      "${_msg[*]}" \
      1
  fi
  _msg=(
    "Found and moving packages '${_pkgs[*]}'"
    "into '${_repo_dir}'."
  )
  _msg_info \
    "${_msg[*]}"
  for _pkg in "${_pkgs[@]}"; do
    _pkgname="$(
      package-info-get \
        "${_pkg}" \
        "pkgname")"
    _msg=(
      "Found and moving package '${_pkg}'"
      "into '${_repo_dir}'."
    )
    _msg_info \
      "${_msg[*]}"
    mv \
      -v \
      "${_pkg}" \
      "${_repo_dir}" || ( \
      _msg=(
        "Error moving '${_pkg}' into"
        "'${_repo_dir}'."  
      ) && \
      _msg_error \
        "${_msg[*]}" \
        1 )
  done
  for _pkg in "${_pkgs[@]}"; do
    _pkg_filename="$(
      basename \
        "${_pkg}")"
    _pkg_file="${_repo_dir}/${_pkg_filename}"
    _pkgname="$(
      package-info-get \
        "${_pkg_file}" \
        "pkgname")"
    _package_retrieved \
      "${_pkgname}"
    tree \
      "${_repo_dir}"
    if [[ "${_dependencies_resolve}" == "n" ]]; then
      _msg=(
        "Skipping dependencies resolving"
        "for '${_pkgname}'."
      )
      _msg_info \
        "${_msg[*]}"
    elif [[ "${_dependencies_resolve}" == "y" ]]; then
      _depends_check \
       "${_repo_dir}/$(
         basename \
           "${_pkg}")"
    fi
  done
  cd \
    "${_oldpwd}"
  rm \
    -rf \
    "${_repo_dir}/fur" || \
    true
  _msg=(
    "Packages retrieved from"
    "branch split fur."
  )
  _msg_info \
    "${_msg[*]}"
}

_fur_ci_get() {
  local \
    _pkg="${1}" \
    _target_mirror="${2}" \
    _repo_dir="${3}"
  if [[ "${_target_mirror}" == "github" ]]; then
    _requirements_github_ci
    _fur_github_release_get \
      "${_pkg}" \
      "${_repo_dir}"
  elif [[ "${_target_mirror}" == "gitlab" ]]; then
    _requirements_gitlab_ci
    _fur_gitlab_release_get \
      "${_pkg}" \
      "${_repo_dir}"
  fi
}

_fur_github_release_get() {
  local \
    _pkg="${1}" \
    _repo_dir="${2}" \
    _msg=() \
    _old_pwd \
    _gur_opts=() \
    _os \
    _arch \
    _pkgs=()
  _os="$(
    uname \
      -o)"
  _arch="$(
    uname \
      -m)"
  if [[ "${quiet}" == "n" ]]; then
    _gur_opts+=(
      -v
    )
  fi
  _gur_opts+=(
    -N
      "${_target_namespace}"
    -m
      "github"
  )
  _old_pwd="${PWD}"
  _msg=(
    "Retrieving binary package"
    "'${_pkg}' from Gur Github"
    "releases from namespace '${_target_namespace}'."
    "Remaining packages '${_packages_to_retrieve[@]}'"
  )
  _msg_info \
    "${_msg[*]}"
  cd \
    "${_repo_dir}"
  gur \
    "${_gur_opts[@]}" \
    get \
      release \
        "${_pkg}"
  if [[ "${_os}" == "Android" ]]; then
    rm \
      -rf \
      "dogeos-gnu"*".pkg.tar"* \
      "dogeos-windows"*".pkg.tar"* || \
      true
    # Arch filter
    if [[ "${_arch}" != "any" ]]; then
      if [[ "${_arch}" == "aarch64" ]]; then
        rm \
          -rf \
          "dogeos-android"*"-arm.pkg.tar"* \
          "dogeos-android"*"-i686.pkg.tar"* \
          "dogeos-android"*"-x86_64.pkg.tar"* || \
        true
      elif [[ "${_arch}" == "arm" ]]; then
        rm \
          -rf \
          "dogeos-android"*"-aarch64.pkg.tar"* \
          "dogeos-android"*"-i686.pkg.tar"* \
          "dogeos-android"*"-x86_64.pkg.tar"*
      elif [[ "${_arch}" == "x86_64" ]]; then
        rm \
          -rf \
          "dogeos-android"*"-aarch64.pkg.tar"* \
          "dogeos-android"*"-arm.pkg.tar"*
          "dogeos-android"*"-i686.pkg.tar"*
      else
        echo \
          "Architecture: '${_arch}'."
      fi
    fi
  elif [[ "${_os}" == "GNU/Linux" ]]; then
    rm \
      -rf \
      "dogeos-android"*".pkg.tar"* \
      "dogeos-windows"*".pkg.tar"*
  elif [[ "${_os}" == "Msys" ]]; then
    rm \
      -rf \
      "dogeos-android"*".pkg.tar"* \
      "dogeos-gnu"*".pkg.tar"*
  fi
  _depends_retrieved+=(
    "${_pkg}"
  )
  _pkgs_plain_get \
    "${_repo_dir}"
  for _pkg in "${_pkgs[@]}"; do
    _pkg_filename="$(
      basename \
        "${_pkg}")"
    # _pkg_file="${_repo_dir}/${_pkg_filename}"
    _pkgname="$(
      package-info-get \
        "${_pkg}" \
        "pkgname")"
    _package_retrieved \
      "${_pkgname}"
    tree \
      "${_repo_dir}"
    if [[ "${_dependencies_resolve}" == "n" ]]; then
      _msg=(
        "Skipping dependencies resolving"
        "for '${_pkgname}'."
      )
      _msg_info \
        "${_msg[*]}"
    elif [[ "${_dependencies_resolve}" == "y" ]]; then
      _depends_check \
       "${_repo_dir}/$(
         basename \
           "${_pkg}")"
    fi
  done
  cd \
    "${_old_pwd}"
}

_fur_gitlab_release_get() {
  local \
    _pkg="${1}" \
    _repo_dir="${2}" \
    _msg=() \
    _old_pwd \
    _gur_opts=() \
    _pkgs=()
  if [[ "${quiet}" == "n" ]]; then
