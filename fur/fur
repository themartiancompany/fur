_repo_dir_auto_detect() {
  local \
    _repo_dir
  _repo_dir="${HOME}/.cache/fur/packages"
  if [[ -e "${_repo_dir}" ]]; then
    mkdir \
      -p \
      "${_repo_dir}"
  fi
  _set_override \
    "repo" \
    "dir" \
    "${_repo_dir}"
}

_package_manager_auto_detect() {
  local \
    _package_manager
  _package_manager="$(
    command \
      -v \
      "inteppacman" || \
    true)"
  if [[ "${_package_manager}" == "" ]]; then
    _package_manager="pacman"
  fi
  _set_override \
    "package" \
    "manager" \
    "${_package_manager}"
}

_mirror_type_auto_detect() {
  if (( "${#mirror_types[@]}" < 1 )); then
    if (( "${#target_namespaces[@]}" < 1 )); then
      mirror_types+=(
        "tree"
        "ci"
      )
    else
      mirror_types+=(
        "ci"
        "tree"
      )
    fi
  fi
}

_target_namespaces_auto_detect() {
  local \
    _gitlab_dir \
    _token \
    _tokens \
    _msg=()
  _gitlab_dir="${HOME}/.config/gitlab.com"
  if [[ -e "${_gitlab_dir}"/* ]]; then
    _tokens="$(
      ls
        "${_gitlab_dir}")"
    if [[ "${_tokens}" != "" ]]; then
      for _token in "${_gitlab_dir}/"*; do
        _namespace_filename="$(
          basename \
            "${_token}")"
        _namespace="${_namespace_filename%*.txt}"
        target_namespaces+=(
          "${_namespace}"
        )
      done
    fi
  fi
  _msg=(
    "Found namespaces '${target_namespaces[*]}'."
  )
  _msg_info \
    "${_msg[*]}"
  true
}

_target_mirrors_auto_detect() {
  local \
    _gitlab_dir \
    _token \
    _tokens \
    _msg=()
  _gitlab_dir="${HOME}/.config/gitlab.com"
  if [[ ! -e "${_gitlab_dir}"/* ]]; then
    target_mirrors+=(
      "github"
      "gitlab"
    )
  else
    _tokens="$(
      ls
        "${_gitlab_dir}")"
    if [[ "${_tokens}" != "" ]]; then
      target_mirrors+=(
        "gitlab"
        "github"
      )
    else
      target_mirrors+=(
        "github"
        "gitlab"
      )
    fi
  fi
}

_cache_clean_auto_detect() {
  local \
    _cache_clean
  _cache_clean="y"
  if [[ "${quiet}" == "n" ]]; then
    _cache_clean="n"
  fi
  _set_override \
    "cache" \
    "clean" \
    "${_cache_clean}"
}

# Set defaults and, if present, overrides
# from fur command line option parameters
_set_overrides() {
  local \
    _msg=()
  if [[ -v override_color ]]; then
    color="${override_color}"
  elif [[ -z "${color}" ]]; then
    color="n"
  fi
  if [[ -v override_quiet ]]; then
    quiet="${override_quiet}"
  elif [[ -z "${quiet}" ]]; then
    quiet="y"
  fi
  _set_override \
    "install" \
    "date" \
    "$(_get_date_human)"
  _set_override \
    "target" \
    "platform" \
    "$(platform-get)"
  _set_override \
    "target" \
    "arch" \
    "$(uname \
         -m)"
  _package_manager_auto_detect
  # TODO:
  # produce a working pacman which can be
  # run as root (see pacman-root-ur tmc repo)
  _repo_dir_auto_detect
  _set_override \
    "download" \
    "only" \
    "false"
  _set_override \
    "target" \
    "namespace" \
    "themartiancompany"
  _cache_clean_auto_detect
  _set_override \
    "repo" \
    "name" \
    "fur"
  _target_namespaces_auto_detect
  _mirror_type_auto_detect
  _target_mirrors_auto_detect
  _set_override \
    "target" \
    "mirror" \
    "${target_mirrors[0]}"
  _set_override \
    "git" \
    "protocol" \
    "http"
  _set_override \
    "dependencies" \
    "check" \
    "y"
  _set_override \
    "dependencies" \
    "resolve" \
    "y"
  _output_dir_auto_detect
  if [[ "${installed_packages[*]}" == "" ]]; then
    installed_packages+=(
      "$(basename \
        "$(realpath \
          "${PWD}")")"
    )
    _msg=(
      "No input package given,"
      "installing ${installed_packages[*]}."
    )
    _msg_info \
      "${_msg[*]}"
  fi
}

