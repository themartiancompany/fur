    # _pkg_file="${_repo_dir}/${_pkg_filename}"
    _pkgname="$(
      package-info-get \
        "${_pkg}" \
        "pkgname")"
    _package_retrieved \
      "${_pkgname}"
    tree \
      "${_repo_dir}"
    if [[ "${_dependencies_resolve}" == "n" ]]; then
      _msg=(
        "Skipping dependencies resolving"
        "for '${_pkgname}'."
      )
      _msg_info \
        "${_msg[*]}"
    elif [[ "${_dependencies_resolve}" == "y" ]]; then
      _depends_check \
       "${_repo_dir}/$(
         basename \
           "${_pkg}")"
    fi
  done
  cd \
    "${_old_pwd}"
