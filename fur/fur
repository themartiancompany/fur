_pkgs_repo_get() {
  local \
    _dir="${1}" \
    _pkgs_array=() \
    _find_opts=() \
    _find_global_opts=()
  _find_global_opts+=(
    -type
      "f"
  )
  _find_opts+=(
    -print0
  )
  mapfile \
    -d \
    $'\0' \
    _pkgs_array < \
    <(find \
        "${_dir}" \
        "${_find_global_opts[@]}" \
        \( \
          -iwholename \
            "*/${_target_platform}/*/*.pkg.*" \
          -a \
        ! -iwholename \
            "*/${_target_platform}/*/*.pkg.*.sig" \
        \) \
        "${_find_opts[@]}" || \
      true)
  _array_set \
    "_pkgs_array" \
    "_pkgs"
}

_pkgs_plain_get() {
  local \
    _dir="${1}" \
    _pkgs_array=() \
    _pkgs_hurr=() \
    _find_opts=() \
    _find_global_opts=()
  _find_global_opts+=(
    -maxdepth
      "1"
    -type
      "f"
  )
  _find_opts+=(
    -print0 
  )
  mapfile \
    -d \
    $'\0' \
    _pkgs_array < \
    <(find \
        "${_dir}" \
        "${_find_global_opts[@]}" \
        \( \
          -iwholename \
            "*.pkg.*" \
          -a \
        ! -iwholename \
            "*.pkg.*.sig" \
        \) \
        "${_find_opts[@]}" || \
      true)
  _array_set \
    "_pkgs_array" \
    "_pkgs_hurr"
  # _pkgs=(
  #   "${_pkgs_array[@]}"
  # )
  _pkgs=()
  for _pkg in "${_pkgs_hurr[@]}"; do
    if [[ -e "${_pkg}" ]]; then
      _pkgs+=(
        "${_pkg}"
      )
    fi
  done
}

_sigs_get() {
  local \
    _dir="${1}"
  mapfile \
    -d \
    $'\0' \
    _sigs < \
    <(find \
        "${_dir}" \
        \( \
          -iwholename \
            "*.pkg.*.sig" \
          -o \
          -iwholename \
            "*.pkg.*.asc" \
        \) \
        -type \
          "f" \
        -print0 || \
      true)
}

_install_pkgs() {
  local \
    _repo_dir="${1}" \
    _sig_dir="${2}" \
    _pkgs=() \
    _sigs=() \
    _sig \
    _cmd=() \
    _sig_verify \
    _msg=() \
    _rm_opts=()
  if [[ "${quiet}" == "y" ]]; then
    rm_opts+=(
      -v
    )
  fi
  _sig_verify="false"
  _msg=(
    "Installing downloaded packages."
  )
  _msg_info \
    "${_msg[*]}"
  if [[ "${_sig_verify}" == "false" ]]; then
    _sigs_get \
      "${_repo_dir}"
    if [[ "${_sigs[*]}" == "" ]]; then
      _msg=(
        "Found no signatures."
      )
      _msg_warning \
        "${_msg[*]}"
    else
      _msg=(
        "Signature verification disabled,"
        "removing all signatures '${_sigs[*]}'."
      )
      _msg_info \
        "${_msg[*]}"
      _rm_opt+=(
        -rf
      )
      rm \
        "${_rm_opts[@]}" \
        "${_sigs[@]}" || \
        true
    fi
  fi
  _pkgs_plain_get \
    "${_repo_dir}"
  _msg=(
    "Installing ${_pkgs[*]}."
  )
  _msg_info \
    "${_msg[*]}"
  _cmd=(
    "${_pkgmgr}"
      "${_pkgmgr_opts[@]}"
      "${_pkgs[@]}"
  )
  _msg_info \
    "Running '${_cmd[*]}'."
  if [[ "${quiet}" == "n" ]]; then
    "${_cmd[@]}"
  elif [[ "${quiet}" == "y" ]]; then
    "${_cmd[@]}" 2 &> \
      /dev/null
  fi
}

_token_private_get() {
  local \
    _token_dir \
    _token_namespace \
    _token_private \
    _file \
    _msg=() \
    _tokens_namespace=()
  _token=""
  _token_name="optional"
  _token_dir="${HOME}/.config/${_domain}.com"
  _token_private="${_token_dir}/default.txt"
  _token_namespace="${_token_dir}/${_namespace}.txt"
  for _file in $(find "${_token_dir}/${_namespace}-"* 2>/dev/null || true); do
    _tokens_namespace+=(
      "${_file}"
    )
  done
  if (( 0 < "${#_tokens_namespace[@]}" )); then
    _msg=(
      "Found '${_namespace}' tokens."
    )
    _msg_info \
      "${_msg[*]}"
    echo \
      "${_tokens_namespace[0]}"
    _token_private="${_tokens_namespace[0]}"
    _token_name="$(
      basename \
        "${_token_private}")"
    _token_name="${_token_name#${_namespace}-}"
    _token_name="${_token_name%.txt}"
  elif [[ -e "${_token_namespace}" ]]; then
    _msg=(
      "Found default token for '${_namespace}'."
    )
    _msg_info \
      "${_msg[*]}"
    _token_private="${_token_namespace}"
  elif [[ ! -e "${_token_namespace}" ]]; then
    _msg=(
      "Found no namespace tokens."
    )
    _msg_info \
      "${_msg[*]}"
  fi
  if [[ -e "${_token_private}" ]]; then
    _msg=(
      "Selected '${_token_private}'."
    )
    _msg_info \
      "${_msg[*]}"
    _token="$(
      cat \
        "${_token_private}")"
  elif [[ -e "${_token_private}" ]]; then
    _msg=(
      "Found no private tokens."
    )
    _msg_info \
      "${_msg[*]}"
  fi
}

_mirror_get() {
  local \
    _domain="${1}" \
    _namespace="${2}" \
    _protocol="${3}" \
    _location \
    _token \
    _token_name
  if [[ "${_protocol}" == "http" ]]; then
    _token_private_get
    if [[ "${_token}" == "" ]]; then
      _msg=(
        "Found no private token,"
        "expecting the repository"
        "to be public."
      )
      _msg_info \
        "${_msg[*]}"
      _location="https://${_domain}.com/"
    elif [[ "${_token}" != "" ]]; then
      if [[ "${_token_name}" == "" ]]; then
        _msg=(
          "Setting dummy name"
        )
        _msg_info \
          "${_msg[*]}"
        _token_name="dummy"
      fi
      _location="https://${_token_name}:${_token}@${_domain}.com/"
    fi
  elif [[ "${_protocol}" == "ssh" ]]; then
    _location="${_domain}:"
  fi
  _url="${_location}${_namespace}/${_repo_name}"
}

_file_hash() {
  local \
    _file="${1}"
  sha256sum \
    "${_file}" | \
    awk \
      '{print $1}'
}

_depend_available_get() {
  local \
    _depend="${1}" \
    _msg=()
  _msg=(
    "Package '${_depend}'"
    "not installed,"
    "checking if available"
    "in default"
    "repositories."
  )
  _msg_info \
    "${_msg[*]}"
  _available="$(
    pacman \
      -Si \
      "${_depend}" \
      2>/dev/null || \
    true)"
}

_install_pkg_repo() {
  local \
    _pkg="${1}" \
    _msg=() \
    _cmd=()
    _pkgmgr_depends_opts=()
  _msg=(
    "The package is available"
    "in default binary repositories,"
    "installing it."
  )
  _pkgmgr_depends_opts+=(
    $(_pkgmgr_depends_opts_get \
        "${_pkgmgr}")
  )
  _cmd=(
    "${_pkgmgr}"
      "${_pkgmgr_depends_opts[@]}"
      "${_pkg}"
  )
  "${_cmd[@]}"
}

_pkg_installed_get() {
  local \
    _pkg="${1}" \
    _msg=()
  msg=(
    "Checking unretrieved"
    "depend '${_depend}'."
  )
  _msg_info \
    "${_msg[*]}"
  _installed="$(
    pacman \
      -Q \
      "${_depend}" 2>/dev/null || \
    true)"
}

_depend_retrieved_get() {
  local \
    _depend="${1}"
  if [[ " ${_depends_retrieved[*]} " != *" ${_depend} "* ]]; then
    _depend_retrieved="false"
  else
    _depend_retrieved="true"
  fi
}

_depend_local_get() {
  local \
    _depend="${1}" \
    _pkg_file \
    _pkgname \
    _pkgs=()
  for _pkg_file in \
    "${_repo_dir}/"*".pkg.tar.xz"; do
    _pkgname="$(
      basename \
        "${_pkg_file}" | \
        rev | \
        cut \
          -d \
            "-" \
          -f \
            4- | \
          rev)"
    _pkgs+=(
      "${_pkgname}"
    )
  done
  if [[ " ${_pkgs[*]} " == *" ${_depend} "* ]]; then
    _msg=(
      "Dependency '${_depend}' already retrieved."
    )
    _msg_info \
      "${_msg[*]}"
    _package_retrieved \
      "${_depend}"
    _depend_retrieved="true"
  fi
}

_depend_resolve() {
  local \
    _depend="${1}" \
    _available \
    _depend_retrieved \
    _installed \
    _msg=()
  _depend_retrieved_get \
    "${_depend}"
  if [[ "${_depend_retrieved}" == "true" ]]; then
    _msg=(
      "Dependency '${_depend}' already retrieved."
    )
    _msg_info \
      "${_msg[*]}"
  elif [[ "${_depend_retrieved}" == "false" ]]; then
    _pkg_installed_get \
      "${_depend}"
    if [[ "${_installed}" == "" ]]; then
      _depend_available_get \
        "${_depend}"
      if [[ "${_available}" != "" ]]; then
        _install_pkg_repo \
          "${_depend}"
      elif [[ "${_available}" == "" ]]; then
        _depend_local_get \
          "${_depend}"
        if [[ "${_depend_retrieved}" == "false" ]]; then
          if [[ " ${_depends_retrieved[*]} " != *" ${_depend} "* ]]; then
            _msg=(
              "Looking for unretrievable"
              "binary package '${_depend}' on"
              "the fur."
            )
            _msg_info \
              "${_msg[*]}"
            _packages_to_retrieve+=(
              "${_depend}"
            )
            "_fur_${_mirror_types[0]}_get" \
              "${_depend}" \
              "${_target_mirror}" \
              "${_repo_dir}"
          elif [[ " ${_depends_retrieved[*]} " == *" ${_depend} "* ]]; then
            _msg=(
              "Package '${_depend}'"
              "already retrieved."
            )
            _msg_info \
              "${_msg[*]}"
          fi
        elif [[ "${_depend_retrieved}" == "true" ]]; then
          _msg=(
            "Depend '${_depend}'"
            "retrieved already."
          )
          _msg_info \
            "${_msg[*]}"
        fi
      fi
    elif [[ "${_installed}" != "" ]]; then
      _package_retrieved \
        "${_depend}"
    fi
  fi
}

_depends_check() {
  local \
    _pkg="${1}" \
    _depend \
    _depend_name \
    _depend_pkgver \
    _depend_target \
    _depends_string \
    _depends=() \
    _msg=() \
    _resolve_flag \
    _separators=()
  _separators=(
    "<="
    ">="
    "<"
    ">"
    "="
  )
  _msg=(
    "Resolving dependencies for"
    "'${_pkgname}'."
  )
  _msg_info \
    "${_msg[*]}"
  _depends_string="$(
    package-info-get \
      "${_pkg}" \
      "depend")"
  IFS=$'\n' \
  read \
    -r \
    -d \
      '' \
    -a \
    _depends <<< \
    "$_depends_string" || \
  true
  if (( "${#_depends[@]}" < 1 )); then
    _msg=(
      "Package '${_pkg}'"
      "has no depends."
    )
    _msg_info \
      "${_msg[*]}"
  elif (( 0 < "${#_depends[@]}" )); then
    for _depend in "${_depends[@]}"; do
      _resolve_flag="false"
      _depend_target="${_depend}"
      for _sep in "${_separators[@]}"; do
        if [[ "${_depend}" == *"${_sep}"* ]]; then
          _depend_name="${_depend%${_sep}*}"
          _depend_pkgver="${_depend#${_depend_name}}"
          _resolve_flag="true"
          _depend_target="${_depend_name}"
          break
        fi
      done
      if [[ "${_resolve_flag}" == "true" ]]; then
        _msg=(
          "It is requested version"
          "'${_depend_pkgver}' of"
          "package '${_depend_name}'."
          "Be aware the Fur doesn't"
          "look for provides currently."
        )
        _msg_info \
          "${_msg[*]}"
      fi
      _depend_resolve \
        "${_depend_target}"
    done
  fi
  true
}

