_release_latest_get_tree() {
  true
}

_release_latest_get_ci() {
  local \
    _package="${1}" \
    _target_mirror="${2}" \
    _target_namespace="${3}" \
    _gur_opts=()
  _gur_opts+=(
    -m
      "${_target_mirror}"
    -N
      "${target_namespace}"
    -d
      "curl"
  )
  # Retrieving latest release
  # using the gur this way it's
  # ill-posed as a release is a
  # 'pkgver-pkgrel' string, so since
  # it sorts the results using sort -V
  # which can fail in cases such as
  # '2.9-1'
  # '2.9a-1'
  # there aren't packages meeting
  # this edge case for now on
  # 'themartiancompany' namespaces
  # but really it needs to be fixed
  # at a later point
  _release="$(
    gur \
      "${_gur_opts[@]}" \
      get \
        releases \
        "${_package}" |
      tail \
        -n \
          1)"
}

_package_release_latest_get() {
  local \
    _package="${1}" \
    _target_mirror="${2}" \
    _target_namespace="${3}" \
    _mirror_type \
    _release
  _msg=(
    "Getting latest release for"
    "package '${_package}' on"
    "namespace '${_target_namespace}'."
  )
  _msg_info \
    "${_msg[*]}"
  for _mirror_type in "${_mirror_types[@]}"; do
    "_release_latest_get_${_mirror_type}" \
      "${_package}" \
      "${_target_mirror}" \
      "${_target_namespace}"
    _release_latest["${_mirror_type}"]="${_release}"
    # Mixed sources retrieval not allowed for now
    break
  done
}

_package_local_check() {
  local \
    _package="${1}" \
    _target_namespace="${2}" \
    _tag="${3}" \
    _gur_opts=() \
    _asset \
    _asset_path \
    _assets_names=()
  _msg=(
    "Getting asset names for"
    "release '${_tag}'."
  )
  _msg_info \
    "${_msg[*]}"
  _gur_opts+=(
    -m
      "${_target_mirror}"
    -N
      "${_target_namespace}"
    -d
      "curl"
  )
  _assets_names=( $(
    gur \
      "${_gur_opts[@]}" \
      get \
        assets_names \
          "${_package}" \
          "${_tag}")
  )
  ls \
    -lsh \
    "${_repo_dir}"
  for _asset in "${_assets_names[@]}"; do
    _asset_path="${_repo_dir}/${_asset}"
    _msg=(
      "Asset '${_asset}'."
    )
    _msg_info \
      "${_msg[*]}"
    if [[ -e "${_asset_path}" ]]; then
      _msg=(
        "Package '${_asset}' with path"
        "'${_asset_path}' already"
        "downloaded."
      )
      _msg_info \
        "${_msg[*]}"
      _sum_remote="$(
        gur \
          "${_gur_opts[@]}" \
          get \
            sum \
              "${_package}" \
              "${_tag}" \
              "${_asset}")"
      _msg=(
        "Remote sum: ${_sum_remote}."
      )
      _sum_local="$(
        sha256sum \
          "${_asset_path}" |
          awk \
            '{print $1}')"
      if [[ "${_sum_local}" == "${_sum_remote}" ]]; then
        _msg=(
          "File checksum correct."
        )
        _msg_info \
          "${_msg[*]}"
        _array_remove \
          "_packages_to_retrieve" \
          "${_package}"
      elif [[ "${_sum_local}" != "${_sum_remote}" ]]; then
        _msg=(
          "File checksum incorrect, re-downloading."
        )
        _msg_info \
          "${_msg[*]}"
      fi
      # TODO:
      # implement signature verification
    fi
  done
  echo \
    "${_assets_names[*]}"
}

# $@: packages
_fur() {
  local \
    _target_platform="${1}" \
    _arch="${2}" \
    _pkgmgr="${3}" \
    _noinstall="${4}" \
    _repo_dir="${5}" \
    _sig_dir="${6}" \
    _target_mirror="${7}" \
    _target_namespace="${8}" \
    _repo_name="${9}" \
    _mirror_type_length="${10}" \
    _mirror_types=() \
    _mirror_type \
    _git_protocol \
    _dependencies_check \
    _dependencies_resolve \
    _output_dir \
    _cache_clean \
    _packages=() \
    _packages_to_retrieve=() \
    _depends_retrieved=() \
    _pkgs=() \
    _pkgmgr_opts=() \
    _clone_opts=() \
    _git_opts=() \
    _pkg \
    _url \
    _msg=()
  for _mirror_type \
    in $(seq \
           "${_mirror_type_length}"); do
    _mirror_types+=(
      "${11}"
    )
    shift
  done
  _git_protocol="${11}"
  _dependencies_check="${12}"
  _dependencies_resolve="${13}"
  _output_dir="${14}"
  _cache_clean="${15}"
  shift \
    15
  _packages=(
    "$@"
  )
  declare \
    -A \
    "_release_latest"
  _msg=(
    "Installing '${_packages[*]}'."
  )
  _msg_info \
    "${_msg[*]}"
  _pkgmgr_opts+=(
    $(_pkgmgr_opts_get \
        "${_pkgmgr}")
  )
  _packages_to_retrieve+=(
    "${_packages[@]}"
  )
  while \
    (( "${#_packages_to_retrieve[@]}" > 0 )); do
    _package="${_packages_to_retrieve[0]}"
    _package_release_latest_get \
      "${_package}" \
      "${_target_mirror}" \
      "${_target_namespace}"
    _msg=(
      "Latest release:"
      "'${_release_latest["${_mirror_types[0]}"]}'."
    )
    _package_local_check \
      "${_package}" \
      "${_target_namespace}" \
      "${_release_latest["${_mirror_types[0]}"]}"
    _msg=(
      "Retrieving package '${_package}'..."
    )
    _msg_info \
      "${_msg[*]}"
    "_fur_${_mirror_types[0]}_get" \
      "${_package}" \
      "${_target_mirror}" \
      "${_repo_dir}"
    _packages_to_retrieve=()
    for _pkg in "${_packages[@]}"; do
      if [[ "${_pkg}" != "${_package}" ]]; then
        _packages_to_retrieve+=(
          "${_pkg}"
        )
      fi
    done
  done
  # for _pkg \
  #   in "${_packages[@]}"; do
    # if [[ "${_noinstall}" == "false" ]]; then
    #   _repo_dir="$(
    #     mktemp \
    #       -d)"
    # fi
  # done
  if [[ "${_noinstall}" == "false" ]]; then
    _install_pkgs \
      "${_repo_dir}" \
      "${_sig_dir}"
  fi
  if [[ "${_cache_clean}" == "y" ]]; then
    rm \
      -rf \
      "${_repo_dir}/"*".pkg.tar."* || \
    true
  fi
  cd \
    "${OLDPWD}"
}

_pkgmgr_depends_opts_get() {
  local \
    _pkgmgr="${1}" \
    _name \
    _opts=()
  _name="$(
    basename \
      "${_pkgmgr}")"
  if [[ "${_name}" == "inteppacman" ]]; then
    if [[ "${quiet}" == "n" ]]; then
      _opts+=(
        -v
      )
    fi
    _opts+=(
      --
    )
  fi
  if [[ "${_dependencies_check}" == "y" ]]; then
    _opts+=(
      -S
    )
  elif [[ "${_dependencies_check}" == "n" ]]; then
    _opts+=(
      -Sdd
    )
  fi
  _opts+=(
    --overwrite="*"
    --noconfirm
  )
  echo \
    "${_opts[@]}"
}

_pkgmgr_opts_get() {
  local \
    _pkgmgr="${1}" \
    _name \
    _opts=()
  _name="$(
    basename \
      "${_pkgmgr}")"
  if [[ "${_name}" == "inteppacman" ]]; then
    if [[ "${quiet}" == "n" ]]; then
      _opts+=(
        -v
      )
    fi
    _opts+=(
      --
    )
  fi
  if [[ "${_dependencies_check}" == "y" ]]; then
    _opts+=(
      -U
    )
  elif [[ "${_dependencies_check}" == "n" ]]; then
    _opts+=(
      -Udd
    )
  fi
  _opts+=(
    --overwrite="*"
    --noconfirm
  )
  echo \
    "${_opts[@]}"
