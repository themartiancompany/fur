# shellcheck disable=SC2004
# shellcheck disable=SC2034
while \
  getopts \
    'P:A:p:dw:K:m:l:n:t:L:D:R:o:Tcvh?' \
    arg; do
  case \
    "${arg}" in
    P)
      override_target_platform="${OPTARG}" ;;
    A)
      override_target_arch="${OPTARG}" ;;
    p)
      override_package_manager="${OPTARG}" ;;
    d)
      override_download_only="true" ;;
    w)
      override_repo_dir="${OPTARG}" ;;
    K)
      override_sig_dir="${OPTARG}" ;;
    m)
      override_target_mirror="${OPTARG}" ;;
    l)
      override_repo_name="${OPTARG}" ;;
    n)
      override_target_namespace="${OPTARG}" ;;
    t)
      mirror_types+=(
         "${OPTARG}"
       ) ;;
    L)
      override_git_protocol="${OPTARG}" ;;
    D)
      override_dependencies_check="${OPTARG}" ;;
    R)
      override_dependencies_resolve="${OPTARG}" ;;
    o)
      override_output_dir="${OPTARG}" ;;
    T)
      override_cache_clean="y" ;;
    c)
      override_color="y" ;;
    v)
      override_quiet="n" ;;
    h|?)
      _set_overrides && \
      _usage \
        0 ;;
    *)
      _msg=(
        "Invalid argument '${arg}'."
      )
      _msg_error \
        "${_msg[*]}" \
        0
      _set_overrides
      _usage \
        1 ;;
  esac
done
shift \
  $(( \
    OPTIND - 1 \
  ))
installed_packages=(
  "$@"
)
